# Copy to .env.local for local development

# Dev auth token (forwarded as access_token cookie to backend proxies)
VITE_DEV_TOKEN=

# Override the API origin (defaults to https://dev.nyai.ai)
# VITE_API_ORIGIN=https://dev.nyai.ai

# Override the API base URL for production (when running behind a gateway, not the Vite proxy)
# VITE_API_BASE=https://api.nyai.ai
